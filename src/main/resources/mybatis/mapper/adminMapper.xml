<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="com.boot.json.model.AdminMapper">

    <!-- 관리자 로그인 (별칭 admin 사용) -->
    <select id="login" resultType="admin">
        SELECT adminId, password, role
        FROM admin1
        WHERE adminId = #{adminId}
    </select>
    
    <!-- 차량 검색 (별칭 car 사용) -->
    <select id="searchCar" resultType="car">
        SELECT carNo, entryTime, exitTime, coupon, storeName 
        FROM car
        <where>
            <if test="field == 'carNo'">
                AND carNo LIKE '%' || #{keyword} || '%'
            </if>
            <if test="field == 'entryTime'">
                AND entryTime LIKE '%' || #{keyword} || '%'
            </if>
            <if test="field == 'exitTime'">
                AND exitTime LIKE '%' || #{keyword} || '%'
            </if>
        </where>
        ORDER BY entryTime DESC
    </select>

    <delete id="deleteCar">
        DELETE FROM car WHERE carNo = #{carNo}
    </delete>

</mapper>
