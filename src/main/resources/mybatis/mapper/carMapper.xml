<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boot.json.model.carMapper">

    <!-- 입차 처리 SQL 쿼리 -->
    <insert id="setParkCar" parameterType="car">
        INSERT INTO car (carNo, entryTime)
        VALUES (#{carNo}, #{entryTime})
    </insert>
    
    <select id="selectCar" parameterType="String" resultType="car">
    	select * from car
    </select>
	
	<update id="setExitCar" parameterType="car">
	    UPDATE cars
	    SET 
	        exitTime = #{exitTime},
	        fee = #{fee},
	        coupon = #{coupon},
	        storeName = #{storeName}
	    WHERE carNo = #{carNo};
	</update>
	
</mapper>
