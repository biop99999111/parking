<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boot.json.model.CarMapper">

    <!-- 입차 처리 SQL 쿼리 -->
    <insert id="setParkCar" parameterType="car">
        INSERT INTO car (carNo, entryTime)
        VALUES (#{carNo}, #{entryTime})
    </insert>
    
    <select id="selectCar" parameterType="String" resultType="car">
    	select * from car
    </select>
	
	<update id="setExitCar" parameterType="car">
	    UPDATE CAR
	    SET exitTime = #{exitTime}
	    WHERE carNo = #{carNo}
	</update>
	
<select id="selectOne" resultType="com.boot.json.model.Car">
    SELECT *
    FROM CAR
    WHERE CARNo LIKE '%' || #{carNo} || '%'
      AND exitTime IS NULL  <!-- 아직 주차 중인 차량만 조회 -->
</select>

	<select id="selectCarByNo" resultType="com.boot.json.model.Car">
    SELECT *
    FROM CAR
    WHERE CARNo LIKE '%' || #{carNo} || '%'
      AND exitTime IS NULL  /* 아직 나가지 않은 차량만 */
    ORDER BY entryTime DESC /* 최신 입차순 정렬 */
</select>
	
	
</mapper>
